{
  "name": "viewerapp",
  "private": true,
  "version": "1.4.5",
  "type": "module",
  "productName": "NODE RF",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "build:exe": "npm run build && npx electron-packager . \"NODE RF\" --platform=win32 --arch=x64 --out=release-builds --overwrite",
    "build:app": "npm run build && electron-builder --win --dir",
    "build:installer": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.node-rf.viewer",
    "productName": "NODE RF",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "package.json",
      "src/core/Constants.js",
      "src/core/RFUtils.js"
    ]
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@tauri-apps/api": "^2.0.1",
    "@tauri-apps/cli": "^2.0.0-rc.18",
    "electron": "^40.8.0",
    "electron-builder": "^25.1.8",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3"
  }
}
